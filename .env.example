# App
APP_NAME=MedPilot
MEDPILOT_ENV=development
MEDPILOT_HOST=127.0.0.1
MEDPILOT_PORT=8000
MEDPILOT_SECRET_KEY=change-me
MEDPILOT_USER_ID=demo-clinician
MEDPILOT_USER_ROLE=clinician
ACTIONS_REQUIRE_CONFIRMATION=true

# OpenMRS
OPENMRS_BASE_URL=http://localhost:8080/openmrs
OPENMRS_USERNAME=admin
OPENMRS_PASSWORD=Admin123
OPENMRS_IDENTIFIER_TYPE_UUID=05a29f94-c0ed-11e2-94be-8c13b969e334
OPENMRS_LOCATION_UUID=8d6c993e-c2cc-11de-8d13-0010c6dffd0f

# Health Gorilla (optional)
HEALTH_GORILLA_BASE_URL=https://sandbox.healthgorilla.com/fhir
HEALTH_GORILLA_TOKEN=
HEALTH_GORILLA_MAX_CONDITIONS=20

# LLM configuration
# Provider options: none, openai, ollama, anthropic
MEDPILOT_LLM_PROVIDER=none
MEDPILOT_LLM_MODEL=
MEDPILOT_LLM_TIMEOUT_SECONDS=30
MEDPILOT_LLM_REASONING_EFFORT=medium
MEDPILOT_LLM_MAX_OUTPUT_TOKENS=2000
MEDPILOT_LLM_ENABLE_INTENT_REASONING=true
MEDPILOT_LLM_ENABLE_SUMMARY_REASONING=true

# OpenAI
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# Ollama
OLLAMA_BASE_URL=http://localhost:11434/api

# Anthropic
ANTHROPIC_API_KEY=

# Runtime and network
REQUEST_TIMEOUT_SECONDS=10
MAX_RETRIES=3
AUDIT_LOG_PATH=data/audit/audit.log
CHAT_SESSIONS_PATH=data/chat/sessions
